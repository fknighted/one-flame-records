# Supabase — Phase 1+
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000         # https://oneflamerecords.com in prod

# Resend — Phase 3+
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@oneflamerecords.com
ADMIN_EMAIL=admin@oneflamerecords.com    # receives new application notifications

# Inngest — Phase 4+
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Anthropic — Phase 4+ (copy generation in AI Studio)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI — Phase 5+ (image generation in AI Studio)
OPENAI_API_KEY=your-openai-api-key

# Meta Graph API — Phase 6+ (Instagram + Facebook auto-posting)
FACEBOOK_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id

# TikTok Content Posting API — Phase 6+ (TikTok auto-posting)
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_OPEN_ID=your-tiktok-open-id

# Video model — Phase 4+
KIE_API_KEY=your-kie-api-key                  # from kie.ai/api-key — proxy for Kling, Veo 3, Seedance etc.
KLING_ACCESS_KEY=your-kling-access-key        # only needed if DEFAULT_VIDEO_MODEL=kling
KLING_SECRET_KEY=your-kling-secret-key        # only needed if DEFAULT_VIDEO_MODEL=kling
HF_CREDENTIALS=your_key_id:your_key_secret    # from cloud.higgsfield.ai → API Keys
DEFAULT_VIDEO_MODEL=kie                        # kie | kling | higgsfield | runway | pika
